# Copy values from this file into .env.local and fill them in.

# consume | enterprise
APP_VARIANT=consume

# Generic fallback (optional)
DATABASE_URL=

# Consume environment
CONSUME_DATABASE_URL=
CONSUME_DB_HOST=
CONSUME_DB_USER=
CONSUME_DB_PASSWORD=
CONSUME_DB_PORT=5432
CONSUME_DB_NAME=
CONSUME_POSTHOG_KEY=
CONSUME_POSTHOG_HOST=
CONSUME_POSTHOG_PROJECT_ID=

# Enterprise environment
ENTERPRISE_DATABASE_URL=
ENTERPRISE_DB_HOST=
ENTERPRISE_DB_USER=
ENTERPRISE_DB_PASSWORD=
ENTERPRISE_DB_PORT=5432
ENTERPRISE_DB_NAME=
ENTERPRISE_POSTHOG_KEY=
ENTERPRISE_POSTHOG_PERSONAL_API_KEY=
ENTERPRISE_POSTHOG_HOST=
ENTERPRISE_POSTHOG_PROJECT_ID=

# Pricing
TOKEN_PRICE_INPUT=1.0
TOKEN_PRICE_OUTPUT=3.0

# Optional integrations
SHORT_IO_API_KEY=
SHORT_IO_DOMAIN_ID=
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
GROQ_API_KEY=

# SendFox for Actions page outreach sync
SENDFOX_ACCESS_TOKEN=
SENDFOX_LIST_MAX_USERS=
SENDFOX_LIST_FREE_ACTIVE=
SENDFOX_LIST_PRO_SUBSCRIBERS=
SENDFOX_LIST_CHURNED_VOLUNTARY=
SENDFOX_LIST_ENTERPRISE_PROSPECTS=
SENDFOX_LIST_CHURN_RISK=
SENDFOX_LIST_ERROR_AFFECTED=
SENDFOX_LIST_RATE_LIMITED=
SENDFOX_LIST_UPGRADE_CANDIDATES=

# Supermemory for Actions page behavior memory
SUPERMEMORY_API_KEY=
SUPERMEMORY_API_BASE_URL=https://api.supermemory.ai
SUPERMEMORY_NAMESPACE=thinkvelocity
SUPERMEMORY_INCLUDE_PII=false
SUPERMEMORY_DREAMING_MODE=dynamic
