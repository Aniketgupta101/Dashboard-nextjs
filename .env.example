# Copy values from this file into .env and fill them in.

# consume | enterprise
APP_VARIANT=consume

# Consume database (use SSH tunnel vars below when DB is not directly reachable)
CONSUME_DB_HOST=
CONSUME_DB_PORT=5433
CONSUME_DB_USER=
CONSUME_DB_PASSWORD=
CONSUME_DB_NAME=

# SSH tunnel for consume DB (run: npm run db:proxy)
SSH_DB_PROXY_LOCAL_HOST=127.0.0.1
SSH_DB_PROXY_LOCAL_PORT=5433
SSH_DB_PROXY_KEY=
SSH_DB_PROXY_TARGET=ubuntu@35.154.138.184
SSH_DB_PROXY_REMOTE_HOST=127.0.0.1
SSH_DB_PROXY_REMOTE_PORT=5432

# Enterprise database
ENTERPRISE_DATABASE_URL=

# Consume PostHog (/api/posthog — Reach page)
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=

# Enterprise PostHog (/api/enterprise-posthog)
ENTERPRISE_POSTHOG_KEY=
ENTERPRISE_POSTHOG_PERSONAL_API_KEY=
ENTERPRISE_POSTHOG_HOST=https://us.i.posthog.com
ENTERPRISE_POSTHOG_PROJECT_ID=

# Pricing
TOKEN_PRICE_INPUT=1.0
TOKEN_PRICE_OUTPUT=3.0

# AI chat (/api/chat, /api/get-data)
GROQ_API_KEY=

# Short.io (Reach page link metrics)
SHORT_IO_API_KEY=
SHORT_IO_DOMAIN_ID=

# Reach / distribution (optional)
PRODUCT_HUNT_TOKEN=
REDDIT_CLIENT_ID=

# SendFox (Actions page outreach sync)
SENDFOX_ACCESS_TOKEN=
SENDFOX_LIST_MAX_USERS=
SENDFOX_LIST_FREE_ACTIVE=
SENDFOX_LIST_PRO_SUBSCRIBERS=
SENDFOX_LIST_CHURNED_VOLUNTARY=
SENDFOX_LIST_ENTERPRISE_PROSPECTS=
SENDFOX_LIST_CHURN_RISK=
SENDFOX_LIST_ERROR_AFFECTED=
SENDFOX_LIST_RATE_LIMITED=
SENDFOX_LIST_UPGRADE_CANDIDATES=

# Supermemory (Actions page behavior memory)
SUPERMEMORY_API_KEY=
SUPERMEMORY_API_BASE_URL=https://api.supermemory.ai
SUPERMEMORY_NAMESPACE=thinkvelocity
SUPERMEMORY_INCLUDE_PII=false
SUPERMEMORY_DREAMING_MODE=dynamic
